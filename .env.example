# Local Development Settings
# Copy this file to .env and fill in your details to run locally

# Your Home Assistant URL (e.g. http://192.168.1.100:8123 or wss://ha.mydomain.com/api/websocket)
# For websocket connections typically ws://IP:8123/api/websocket
HA_URL=ws://192.168.X.X:8123/api/websocket

# Long-lived access token from your Home Assistant profile
HA_TOKEN=your_long_lived_access_token_here

# Directory where automations are stored
AUTOMATIONS_DIR=./automations
